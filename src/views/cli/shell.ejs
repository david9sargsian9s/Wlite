<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>WLite - Terminal Shell</title>
    <!-- Connecting Xterm.js styles -->
    <link rel="stylesheet" href="/css/shell.css" />
    <link rel="stylesheet" href="/css/xterm.css" />
    <style>
        body { background: #1a1a1a; margin: 0; padding: 20px; font-family: monospace; }
        #terminal-container {
            width: 100%;
            height: 80vh;
            background: #000;
            padding: 10px;
            border-radius: 6px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }
    </style>
</head>
<body>

    <!-- Xterm.js will embed its canvas here. -->
    <div id="terminal-container" data-username="<%= username %>" style="height: 80vh;"></div>

    <!-- Connecting the library script -->
    <script src="/js/xterm.js"></script>
    
    <!-- Connecting your OS logic -->
    <script src="/js/shell-core.js"></script>
</body>
</html>
